{
  "$defs": {
    "ActionIntent": {
      "properties": {
        "avatar_id": {
          "title": "Avatar Id",
          "type": "string"
        },
        "duration_ms": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Duration Ms"
        },
        "kind": {
          "enum": [
            "expression",
            "action",
            "reaction"
          ],
          "title": "Kind",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "strength": {
          "default": 1.0,
          "title": "Strength",
          "type": "number"
        }
      },
      "required": [
        "avatar_id",
        "duration_ms",
        "kind",
        "name",
        "strength"
      ],
      "title": "ActionIntent",
      "type": "object"
    },
    "DisplayTextField": {
      "description": "Mirrors OLVT DisplayText.to_dict() -- see output_types.py:36-39.",
      "properties": {
        "avatar": {
          "default": "teto",
          "title": "Avatar",
          "type": "string"
        },
        "name": {
          "default": "Teto",
          "title": "Name",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "avatar",
        "name",
        "text"
      ],
      "title": "DisplayTextField",
      "type": "object"
    }
  },
  "properties": {
    "actions": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ActionIntent"
      },
      "title": "Actions",
      "type": "array"
    },
    "audio": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Audio"
    },
    "display_text": {
      "$ref": "#/$defs/DisplayTextField"
    },
    "forwarded": {
      "default": false,
      "title": "Forwarded",
      "type": "boolean"
    },
    "sentence_id": {
      "title": "Sentence Id",
      "type": "integer"
    },
    "slice_length": {
      "default": 20,
      "title": "Slice Length",
      "type": "integer"
    },
    "type": {
      "const": "audio",
      "default": "audio",
      "title": "Type",
      "type": "string"
    },
    "volumes": {
      "default": [],
      "items": {
        "type": "number"
      },
      "title": "Volumes",
      "type": "array"
    }
  },
  "required": [
    "actions",
    "audio",
    "display_text",
    "forwarded",
    "sentence_id",
    "slice_length",
    "type",
    "volumes"
  ],
  "title": "AudioPayloadMessage",
  "type": "object"
}
