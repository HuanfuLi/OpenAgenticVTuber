{
  "$defs": {
    "ActionCode": {
      "properties": {
        "kind": {
          "const": "action",
          "default": "action",
          "title": "Kind",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "name"
      ],
      "title": "ActionCode",
      "type": "object"
    },
    "DisplayTextField": {
      "description": "Mirrors OLVT DisplayText.to_dict() -- see output_types.py:36-39.",
      "properties": {
        "avatar": {
          "default": "teto",
          "title": "Avatar",
          "type": "string"
        },
        "name": {
          "default": "Teto",
          "title": "Name",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "avatar",
        "name",
        "text"
      ],
      "title": "DisplayTextField",
      "type": "object"
    },
    "EventFire": {
      "properties": {
        "duration_ms": {
          "title": "Duration Ms",
          "type": "integer"
        },
        "hotkey_id": {
          "title": "Hotkey Id",
          "type": "string"
        },
        "kind": {
          "const": "event",
          "default": "event",
          "title": "Kind",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "duration_ms",
        "hotkey_id",
        "kind",
        "name"
      ],
      "title": "EventFire",
      "type": "object"
    },
    "FailedAudioMetadata": {
      "properties": {
        "provider_id": {
          "enum": [
            "piper",
            "gpt_sovits",
            "funasr",
            "faster_whisper",
            "openai",
            "groq"
          ],
          "title": "Provider Id",
          "type": "string"
        },
        "redacted_diagnostics": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Redacted Diagnostics"
        },
        "retryable": {
          "default": false,
          "title": "Retryable",
          "type": "boolean"
        },
        "state": {
          "enum": [
            "ok",
            "unavailable",
            "missing_credential",
            "external_service_failure",
            "timeout",
            "misconfigured"
          ],
          "title": "State",
          "type": "string"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "provider_id",
        "redacted_diagnostics",
        "retryable",
        "state",
        "summary"
      ],
      "title": "FailedAudioMetadata",
      "type": "object"
    },
    "VariantToggle": {
      "properties": {
        "hotkey_id": {
          "title": "Hotkey Id",
          "type": "string"
        },
        "kind": {
          "const": "variant",
          "default": "variant",
          "title": "Kind",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "hotkey_id",
        "kind",
        "name"
      ],
      "title": "VariantToggle",
      "type": "object"
    }
  },
  "properties": {
    "audio": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Audio"
    },
    "dispatches": {
      "default": [],
      "items": {
        "discriminator": {
          "mapping": {
            "action": "#/$defs/ActionCode",
            "event": "#/$defs/EventFire",
            "variant": "#/$defs/VariantToggle"
          },
          "propertyName": "kind"
        },
        "oneOf": [
          {
            "$ref": "#/$defs/ActionCode"
          },
          {
            "$ref": "#/$defs/VariantToggle"
          },
          {
            "$ref": "#/$defs/EventFire"
          }
        ]
      },
      "title": "Dispatches",
      "type": "array"
    },
    "display_text": {
      "$ref": "#/$defs/DisplayTextField"
    },
    "failed_audio": {
      "anyOf": [
        {
          "$ref": "#/$defs/FailedAudioMetadata"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "forwarded": {
      "default": false,
      "title": "Forwarded",
      "type": "boolean"
    },
    "sentence_id": {
      "title": "Sentence Id",
      "type": "integer"
    },
    "slice_length": {
      "default": 20,
      "title": "Slice Length",
      "type": "integer"
    },
    "type": {
      "const": "audio",
      "default": "audio",
      "title": "Type",
      "type": "string"
    },
    "volumes": {
      "default": [],
      "items": {
        "type": "number"
      },
      "title": "Volumes",
      "type": "array"
    }
  },
  "required": [
    "audio",
    "dispatches",
    "display_text",
    "failed_audio",
    "forwarded",
    "sentence_id",
    "slice_length",
    "type",
    "volumes"
  ],
  "title": "AudioPayloadMessage",
  "type": "object"
}
