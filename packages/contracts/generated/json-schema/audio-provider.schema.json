{
  "$defs": {
    "AudioConfig": {
      "properties": {
        "diagnostics": {
          "$ref": "#/$defs/AudioDiagnosticsConfig",
          "default": {
            "redact_diagnostics": true
          }
        },
        "schema_version": {
          "const": 1,
          "default": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "stt": {
          "$ref": "#/$defs/STTProviderConfig",
          "default": {
            "active_provider": null,
            "capture_timeout_ms": 30000,
            "cloud": {
              "groq": {
                "api_key": null,
                "consent_granted": false,
                "endpoint_url": null,
                "model_name": null,
                "provider_id": "groq"
              },
              "openai": {
                "api_key": null,
                "consent_granted": false,
                "endpoint_url": null,
                "model_name": null,
                "provider_id": "openai"
              }
            },
            "enabled": false,
            "execution": "off_event_loop",
            "input_mode": "push_to_talk",
            "language_mode": "auto"
          }
        },
        "tts": {
          "$ref": "#/$defs/TTSProviderConfig",
          "default": {
            "active_provider": "piper",
            "gpt_sovits": null,
            "piper": {
              "execution": "off_event_loop",
              "ordered_playback": true,
              "output_device": null,
              "provider_id": "piper",
              "rms_lipsync": true,
              "synthesis_timeout_ms": 30000,
              "voice_model": "en_US-amy-medium"
            }
          }
        }
      },
      "required": [
        "diagnostics",
        "schema_version",
        "stt",
        "tts"
      ],
      "title": "AudioConfig",
      "type": "object"
    },
    "AudioDiagnosticsConfig": {
      "properties": {
        "redact_diagnostics": {
          "default": true,
          "title": "Redact Diagnostics",
          "type": "boolean"
        }
      },
      "required": [
        "redact_diagnostics"
      ],
      "title": "AudioDiagnosticsConfig",
      "type": "object"
    },
    "AudioProviderCatalog": {
