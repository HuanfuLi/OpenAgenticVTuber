    "AudioProviderHealth": {
      "properties": {
        "detail": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Detail"
        },
        "kind": {
          "enum": [
            "tts",
            "stt"
          ],
          "title": "Kind",
          "type": "string"
