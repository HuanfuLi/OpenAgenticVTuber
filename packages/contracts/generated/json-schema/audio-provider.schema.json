{
  "$defs": {
    "AudioConfig": {
      "properties": {
        "schema_version": {
          "const": 1,
          "default": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "stt": {
          "$ref": "#/$defs/STTProviderConfig",
          "default": {
            "active_provider": null,
            "capture_timeout_ms": 30000,
            "enabled": false,
            "execution": "off_event_loop"
          }
        },
        "tts": {
          "$ref": "#/$defs/TTSProviderConfig",
          "default": {
            "active_provider": "piper",
            "gpt_sovits": null,
            "piper": {
              "execution": "off_event_loop",
              "ordered_playback": true,
              "output_device": null,
              "provider_id": "piper",
              "rms_lipsync": true,
              "synthesis_timeout_ms": 30000,
              "voice_model": "en_US-amy-medium"
            }
          }
        }
      },
      "required": [
        "schema_version",
        "stt",
        "tts"
      ],
      "title": "AudioConfig",
      "type": "object"
    },
    "AudioProviderHealth": {
      "properties": {
        "detail": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Detail"
        },
        "kind": {
          "enum": [
            "tts",
            "stt"
          ],
          "title": "Kind",
          "type": "string"
        },
        "latency_ms": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Latency Ms"
        },
        "provider_id": {
          "enum": [
            "piper",
            "gpt_sovits",
            "funasr",
            "faster_whisper",
            "openai",
            "groq"
          ],
          "title": "Provider Id",
          "type": "string"
        },
        "redacted_diagnostics": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Redacted Diagnostics"
        },
        "retryable": {
          "default": false,
          "title": "Retryable",
          "type": "boolean"
        },
        "state": {
          "enum": [
            "ok",
            "unavailable",
            "missing_credential",
            "external_service_failure",
            "timeout",
            "misconfigured"
          ],
          "title": "State",
          "type": "string"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "detail",
        "kind",
        "latency_ms",
        "provider_id",
        "redacted_diagnostics",
        "retryable",
        "state",
        "summary"
      ],
      "title": "AudioProviderHealth",
      "type": "object"
    },
    "GptSoVitsActivationGate": {
      "properties": {
        "active_allowed": {
          "default": false,
          "title": "Active Allowed",
          "type": "boolean"
        },
        "health_check_passed": {
          "default": false,
          "title": "Health Check Passed",
          "type": "boolean"
        },
        "last_health_checked_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Health Checked At"
        },
        "last_test_synthesis_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Test Synthesis At"
        },
        "test_synthesis_passed": {
          "default": false,
          "title": "Test Synthesis Passed",
          "type": "boolean"
        }
      },
      "required": [
        "active_allowed",
        "health_check_passed",
        "last_health_checked_at",
        "last_test_synthesis_at",
        "test_synthesis_passed"
      ],
      "title": "GptSoVitsActivationGate",
      "type": "object"
    },
    "GptSoVitsHealthRequest": {
      "properties": {
        "config": {
          "$ref": "#/$defs/GptSoVitsProviderConfig"
        }
      },
      "required": [
        "config"
      ],
      "title": "GptSoVitsHealthRequest",
      "type": "object"
    },
    "GptSoVitsLaunchConfig": {
      "properties": {
        "auto_start": {
          "default": false,
          "title": "Auto Start",
          "type": "boolean"
        },
        "command": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Command"
        },
        "mode": {
          "default": "external",
          "enum": [
            "external",
            "app_managed"
          ],
          "title": "Mode",
          "type": "string"
        },
        "working_directory": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Working Directory"
        }
      },
      "required": [
        "auto_start",
        "command",
        "mode",
        "working_directory"
      ],
      "title": "GptSoVitsLaunchConfig",
      "type": "object"
    },
    "GptSoVitsPresetConfig": {
      "properties": {
        "batch_size": {
          "default": 1,
          "minimum": 1,
          "title": "Batch Size",
          "type": "integer"
        },
        "media_type": {
          "const": "wav",
          "default": "wav",
          "title": "Media Type",
          "type": "string"
        },
        "prompt_lang": {
          "default": "ja",
          "enum": [
            "zh",
            "en",
            "ja",
            "ko",
            "yue",
            "auto"
          ],
          "title": "Prompt Lang",
          "type": "string"
        },
        "prompt_text": {
          "default": "",
          "title": "Prompt Text",
          "type": "string"
        },
        "reference_audio_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reference Audio Id"
        },
        "repetition_penalty": {
          "default": 1.35,
          "minimum": 0.0,
          "title": "Repetition Penalty",
          "type": "number"
        },
        "speed_factor": {
          "default": 1.0,
          "exclusiveMinimum": 0.0,
          "title": "Speed Factor",
          "type": "number"
        },
        "streaming_mode": {
          "default": false,
          "title": "Streaming Mode",
          "type": "boolean"
        },
        "temperature": {
          "default": 1.0,
          "minimum": 0.0,
          "title": "Temperature",
          "type": "number"
        },
        "text_lang": {
          "default": "ja",
          "enum": [
            "zh",
            "en",
            "ja",
            "ko",
            "yue",
            "auto"
          ],
          "title": "Text Lang",
          "type": "string"
        },
        "text_split_method": {
          "default": "cut5",
          "title": "Text Split Method",
          "type": "string"
        },
        "top_k": {
          "default": 15,
          "minimum": 1,
          "title": "Top K",
          "type": "integer"
        },
        "top_p": {
          "default": 1.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Top P",
          "type": "number"
        }
      },
      "required": [
        "batch_size",
        "media_type",
        "prompt_lang",
        "prompt_text",
        "reference_audio_id",
        "repetition_penalty",
        "speed_factor",
        "streaming_mode",
        "temperature",
        "text_lang",
        "text_split_method",
        "top_k",
        "top_p"
      ],
      "title": "GptSoVitsPresetConfig",
      "type": "object"
    },
    "GptSoVitsProviderConfig": {
      "properties": {
        "activation": {
          "$ref": "#/$defs/GptSoVitsActivationGate",
          "default": {
            "active_allowed": false,
            "health_check_passed": false,
            "last_health_checked_at": null,
            "last_test_synthesis_at": null,
            "test_synthesis_passed": false
          }
        },
        "base_url": {
          "default": "http://127.0.0.1:9880",
          "minLength": 1,
          "title": "Base Url",
          "type": "string"
        },
        "enabled": {
          "default": false,
          "title": "Enabled",
          "type": "boolean"
        },
        "launch": {
          "$ref": "#/$defs/GptSoVitsLaunchConfig",
          "default": {
            "auto_start": false,
            "command": null,
            "mode": "external",
            "working_directory": null
          }
        },
        "provider_id": {
          "const": "gpt_sovits",
          "default": "gpt_sovits",
          "title": "Provider Id",
          "type": "string"
        },
        "request_timeout_ms": {
          "default": 30000,
          "minimum": 1000,
          "title": "Request Timeout Ms",
          "type": "integer"
        }
      },
      "required": [
        "activation",
        "base_url",
        "enabled",
        "launch",
        "provider_id",
        "request_timeout_ms"
      ],
      "title": "GptSoVitsProviderConfig",
      "type": "object"
    },
    "GptSoVitsTestSynthesisRequest": {
      "properties": {
        "config": {
          "$ref": "#/$defs/GptSoVitsProviderConfig"
        },
        "preset": {
          "$ref": "#/$defs/VoicePreset"
        },
        "text": {
          "minLength": 1,
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "config",
        "preset",
        "text"
      ],
      "title": "GptSoVitsTestSynthesisRequest",
      "type": "object"
    },
    "GptSoVitsTestSynthesisResult": {
      "properties": {
        "audio_base64": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Audio Base64"
        },
        "duration_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Duration Ms"
        },
        "failure": {
          "anyOf": [
            {
              "$ref": "#/$defs/AudioProviderHealth"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "media_type": {
          "const": "wav",
          "default": "wav",
          "title": "Media Type",
          "type": "string"
        },
        "ok": {
          "title": "Ok",
          "type": "boolean"
        },
        "provider_id": {
          "const": "gpt_sovits",
          "default": "gpt_sovits",
          "title": "Provider Id",
          "type": "string"
        },
        "sample_rate_hz": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sample Rate Hz"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "audio_base64",
        "duration_ms",
        "failure",
        "media_type",
        "ok",
        "provider_id",
        "sample_rate_hz",
        "summary"
      ],
      "title": "GptSoVitsTestSynthesisResult",
      "type": "object"
    },
    "PiperTTSConfig": {
      "properties": {
        "execution": {
          "const": "off_event_loop",
          "default": "off_event_loop",
          "title": "Execution",
          "type": "string"
        },
        "ordered_playback": {
          "default": true,
          "title": "Ordered Playback",
          "type": "boolean"
        },
        "output_device": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Output Device"
        },
        "provider_id": {
          "const": "piper",
          "default": "piper",
          "title": "Provider Id",
          "type": "string"
        },
        "rms_lipsync": {
          "default": true,
          "title": "Rms Lipsync",
          "type": "boolean"
        },
        "synthesis_timeout_ms": {
          "default": 30000,
          "minimum": 1000,
          "title": "Synthesis Timeout Ms",
          "type": "integer"
        },
        "voice_model": {
          "default": "en_US-amy-medium",
          "title": "Voice Model",
          "type": "string"
        }
      },
      "required": [
        "execution",
        "ordered_playback",
        "output_device",
        "provider_id",
        "rms_lipsync",
        "synthesis_timeout_ms",
        "voice_model"
      ],
      "title": "PiperTTSConfig",
      "type": "object"
    },
    "STTProviderConfig": {
      "properties": {
        "active_provider": {
          "anyOf": [
            {
              "enum": [
                "funasr",
                "faster_whisper",
                "openai",
                "groq"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Active Provider"
        },
        "capture_timeout_ms": {
          "default": 30000,
          "minimum": 1000,
          "title": "Capture Timeout Ms",
          "type": "integer"
        },
        "enabled": {
          "default": false,
          "title": "Enabled",
          "type": "boolean"
        },
        "execution": {
          "const": "off_event_loop",
          "default": "off_event_loop",
          "title": "Execution",
          "type": "string"
        }
      },
      "required": [
        "active_provider",
        "capture_timeout_ms",
        "enabled",
        "execution"
      ],
      "title": "STTProviderConfig",
      "type": "object"
    },
    "TTSProviderConfig": {
      "properties": {
        "active_provider": {
          "default": "piper",
          "enum": [
            "piper",
            "gpt_sovits"
          ],
          "title": "Active Provider",
          "type": "string"
        },
        "gpt_sovits": {
          "anyOf": [
            {
              "$ref": "#/$defs/GptSoVitsProviderConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "piper": {
          "$ref": "#/$defs/PiperTTSConfig",
          "default": {
            "execution": "off_event_loop",
            "ordered_playback": true,
            "output_device": null,
            "provider_id": "piper",
            "rms_lipsync": true,
            "synthesis_timeout_ms": 30000,
            "voice_model": "en_US-amy-medium"
          }
        }
      },
      "required": [
        "active_provider",
        "gpt_sovits",
        "piper"
      ],
      "title": "TTSProviderConfig",
      "type": "object"
    },
    "VoicePreset": {
      "properties": {
        "created_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Created At"
        },
        "gpt_sovits": {
          "$ref": "#/$defs/GptSoVitsPresetConfig",
          "default": {
            "batch_size": 1,
            "media_type": "wav",
            "prompt_lang": "ja",
            "prompt_text": "",
            "reference_audio_id": null,
            "repetition_penalty": 1.35,
            "speed_factor": 1.0,
            "streaming_mode": false,
            "temperature": 1.0,
            "text_lang": "ja",
            "text_split_method": "cut5",
            "top_k": 15,
            "top_p": 1.0
          }
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "piper_voice_model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Piper Voice Model"
        },
        "preset_id": {
          "minLength": 1,
          "title": "Preset Id",
          "type": "string"
        },
        "provider_id": {
          "default": "piper",
          "enum": [
            "piper",
            "gpt_sovits"
          ],
          "title": "Provider Id",
          "type": "string"
        },
        "updated_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Updated At"
        }
      },
      "required": [
        "created_at",
        "gpt_sovits",
        "name",
        "piper_voice_model",
        "preset_id",
        "provider_id",
        "updated_at"
      ],
      "title": "VoicePreset",
      "type": "object"
    }
  },
  "properties": {
    "audio_config": {
      "$ref": "#/$defs/AudioConfig",
      "default": {
        "schema_version": 1,
        "stt": {
          "active_provider": null,
          "capture_timeout_ms": 30000,
          "enabled": false,
          "execution": "off_event_loop"
        },
        "tts": {
          "active_provider": "piper",
          "gpt_sovits": null,
          "piper": {
            "execution": "off_event_loop",
            "ordered_playback": true,
            "output_device": null,
            "provider_id": "piper",
            "rms_lipsync": true,
            "synthesis_timeout_ms": 30000,
            "voice_model": "en_US-amy-medium"
          }
        }
      }
    },
    "gpt_sovits_health_request": {
      "anyOf": [
        {
          "$ref": "#/$defs/GptSoVitsHealthRequest"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "gpt_sovits_test_synthesis_request": {
      "anyOf": [
        {
          "$ref": "#/$defs/GptSoVitsTestSynthesisRequest"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "gpt_sovits_test_synthesis_result": {
      "anyOf": [
        {
          "$ref": "#/$defs/GptSoVitsTestSynthesisResult"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "audio_config",
    "gpt_sovits_health_request",
    "gpt_sovits_test_synthesis_request",
    "gpt_sovits_test_synthesis_result"
  ],
  "title": "AudioProviderContracts",
  "type": "object"
}
