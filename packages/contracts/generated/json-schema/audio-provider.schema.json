        "display_name": {
          "title": "Display Name",
          "type": "string"
        },
        "enabled": {
          "default": true,
          "title": "Enabled",
          "type": "boolean"
        },
        "kind": {
          "enum": [
            "tts",
            "stt"
          ],
          "title": "Kind",
          "type": "string"
        },
        "local": {
          "title": "Local",
          "type": "boolean"
        },
        "provider_id": {
          "enum": [
            "piper",
            "gpt_sovits",
            "funasr",
            "faster_whisper",
            "openai",
