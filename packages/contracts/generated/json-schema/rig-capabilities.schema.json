{
  "$defs": {
    "DefaultPluginActionBinding": {
      "properties": {
        "action_code": {
          "pattern": "^[a-z][a-z0-9-]{0,30}$",
          "title": "Action Code",
          "type": "string"
        },
        "expression_index": {
          "minimum": 0,
          "title": "Expression Index",
          "type": "integer"
        },
        "expression_name": {
          "default": "",
          "title": "Expression Name",
          "type": "string"
        },
        "plugin_name": {
          "const": "default",
          "default": "default",
          "title": "Plugin Name",
          "type": "string"
        },
        "source": {
          "default": "olvt_emotionMap",
          "enum": [
            "olvt_emotionMap",
            "manual"
          ],
          "title": "Source",
          "type": "string"
        }
      },
      "required": [
        "action_code",
        "expression_index",
        "expression_name",
        "plugin_name",
        "source"
      ],
      "title": "DefaultPluginActionBinding",
      "type": "object"
    },
    "Expression": {
      "properties": {
        "file": {
          "title": "File",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "file",
        "name"
      ],
      "title": "Expression",
      "type": "object"
    },
    "Hotkey": {
      "properties": {
        "hotkey_id": {
          "title": "Hotkey Id",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "type": {
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "hotkey_id",
        "name",
        "type"
      ],
      "title": "Hotkey",
      "type": "object"
    }
  },
  "properties": {
    "cdi3_display_names": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Cdi3 Display Names",
      "type": "object"
    },
    "default_plugin_action_bindings": {
      "items": {
        "$ref": "#/$defs/DefaultPluginActionBinding"
      },
      "title": "Default Plugin Action Bindings",
      "type": "array"
    },
    "expressions": {
      "items": {
        "$ref": "#/$defs/Expression"
      },
      "title": "Expressions",
      "type": "array"
    },
    "hotkeys": {
      "items": {
        "$ref": "#/$defs/Hotkey"
      },
      "title": "Hotkeys",
      "type": "array"
    },
    "param_ranges": {
      "additionalProperties": {
        "anyOf": [
          {
            "maxItems": 2,
            "minItems": 2,
            "prefixItems": [
              {
                "type": "number"
              },
              {
                "type": "number"
              }
            ],
            "type": "array"
          },
          {
            "type": "null"
          }
        ]
      },
      "title": "Param Ranges",
      "type": "object"
    },
    "sign_inversions": {
      "items": {
        "type": "string"
      },
      "title": "Sign Inversions",
      "type": "array"
    },
    "writable_param_ids": {
      "items": {
        "type": "string"
      },
      "title": "Writable Param Ids",
      "type": "array"
    }
  },
  "title": "RigCapabilities",
  "type": "object"
}
