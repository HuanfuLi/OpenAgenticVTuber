    "VariantToggle": {
      "properties": {
        "hotkey_id": {
          "title": "Hotkey Id",
          "type": "string"
        },
        "kind": {
          "const": "variant",
          "default": "variant",
          "title": "Kind",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "hotkey_id",
        "kind",
        "name"
      ],
      "title": "VariantToggle",
      "type": "object"
    }
  },
  "discriminator": {
    "mapping": {
      "audio": "#/$defs/AudioPayloadMessage",
      "control": "#/$defs/ControlMessage",
      "display-text": "#/$defs/DisplayTextMessage",
      "error": "#/$defs/ErrorMessage",
      "force-new-message": "#/$defs/ForceNewMessageMessage",
      "full-text": "#/$defs/FullTextMessage",
      "log": "#/$defs/LogMessage",
      "shutdown": "#/$defs/ShutdownMessage",
      "text-input": "#/$defs/TextInputMessage"
