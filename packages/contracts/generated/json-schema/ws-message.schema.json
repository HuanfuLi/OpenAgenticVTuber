        "type": {
          "const": "force-new-message",
          "default": "force-new-message",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "title": "ForceNewMessageMessage",
      "type": "object"
    },
    "FullTextMessage": {
      "description": "OLVT conversation_utils.py:143 -- turn-start \"Thinking...\" echo (D-03).",
      "properties": {
        "text": {
          "title": "Text",
          "type": "string"
        },
        "type": {
          "const": "full-text",
          "default": "full-text",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "text",
        "type"
      ],
      "title": "FullTextMessage",
      "type": "object"
    },
    "LogMessage": {
      "description": "Sidecar stdout/loguru bridge to renderer Logs drawer (Phase 1 channel,\nre-used in Phase 2 for [INTENT] and [STUB-TTS] lines per D-14, D-23).",
      "properties": {
        "level": {
          "title": "Level",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "type": {
          "const": "log",
          "default": "log",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "level",
        "message",
        "type"
      ],
      "title": "LogMessage",
      "type": "object"
    },
    "ShutdownMessage": {
      "properties": {
        "type": {
          "const": "shutdown",
          "default": "shutdown",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "title": "ShutdownMessage",
      "type": "object"
    },
    "TextInputMessage": {
      "properties": {
        "text": {
          "title": "Text",
          "type": "string"
        },
        "type": {
          "const": "text-input",
          "default": "text-input",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "text",
        "type"
      ],
      "title": "TextInputMessage",
      "type": "object"
