    "propertyName": "type"
  },
  "oneOf": [
    {
      "$ref": "#/$defs/TextInputMessage"
    },
    {
      "$ref": "#/$defs/DisplayTextMessage"
    },
    {
      "$ref": "#/$defs/ShutdownMessage"
    },
    {
      "$ref": "#/$defs/AudioPayloadMessage"
    },
    {
      "$ref": "#/$defs/ControlMessage"
    },
    {
      "$ref": "#/$defs/FullTextMessage"
    },
    {
      "$ref": "#/$defs/ForceNewMessageMessage"
    },
    {
      "$ref": "#/$defs/ErrorMessage"
    },
    {
      "$ref": "#/$defs/LogMessage"
    }
  ]
}
