{
  "$defs": {
    "ActionCode": {
      "properties": {
        "kind": {
          "const": "action",
          "default": "action",
          "title": "Kind",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "name"
      ],
      "title": "ActionCode",
      "type": "object"
    },
    "AudioPayloadMessage": {
      "properties": {
        "audio": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Audio"
        },
        "dispatches": {
          "default": [],
          "items": {
            "discriminator": {
              "mapping": {
                "action": "#/$defs/ActionCode",
                "event": "#/$defs/EventFire",
                "variant": "#/$defs/VariantToggle"
              },
              "propertyName": "kind"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/ActionCode"
              },
              {
                "$ref": "#/$defs/VariantToggle"
              },
              {
                "$ref": "#/$defs/EventFire"
              }
            ]
          },
          "title": "Dispatches",
          "type": "array"
        },
        "display_text": {
          "$ref": "#/$defs/DisplayTextField"
        },
        "forwarded": {
          "default": false,
          "title": "Forwarded",
          "type": "boolean"
        },
        "sentence_id": {
          "title": "Sentence Id",
          "type": "integer"
        },
        "slice_length": {
          "default": 20,
          "title": "Slice Length",
          "type": "integer"
        },
        "type": {
          "const": "audio",
          "default": "audio",
          "title": "Type",
          "type": "string"
        },
        "volumes": {
          "default": [],
          "items": {
            "type": "number"
          },
          "title": "Volumes",
          "type": "array"
        }
      },
      "required": [
        "audio",
        "dispatches",
        "display_text",
        "forwarded",
        "sentence_id",
        "slice_length",
        "type",
        "volumes"
      ],
      "title": "AudioPayloadMessage",
      "type": "object"
    },
    "ControlMessage": {
      "description": "OLVT conversation_utils.py:138-204 control signals.\ntext values used in Phase 2:\n  - \"conversation-chain-start\"  (D-03)\n  - \"conversation-chain-end\"    (D-04)",
      "properties": {
        "text": {
          "title": "Text",
          "type": "string"
        },
        "type": {
          "const": "control",
          "default": "control",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "text",
        "type"
      ],
      "title": "ControlMessage",
      "type": "object"
    },
    "DisplayTextField": {
      "description": "Mirrors OLVT DisplayText.to_dict() -- see output_types.py:36-39.",
      "properties": {
        "avatar": {
          "default": "teto",
          "title": "Avatar",
          "type": "string"
        },
        "name": {
          "default": "Teto",
          "title": "Name",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "avatar",
        "name",
        "text"
      ],
      "title": "DisplayTextField",
      "type": "object"
    },
    "DisplayTextMessage": {
      "properties": {
        "text": {
          "title": "Text",
          "type": "string"
        },
        "type": {
          "const": "display-text",
          "default": "display-text",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "text",
        "type"
      ],
      "title": "DisplayTextMessage",
      "type": "object"
    },
    "ErrorMessage": {
      "description": "Surfaced as a banner above the chat input (CHAT.STREAM_ERROR or\nCHAT.CONTEXT_OVERFLOW per UI-SPEC Copywriting Contract).",
      "properties": {
        "message": {
          "title": "Message",
          "type": "string"
        },
        "type": {
          "const": "error",
          "default": "error",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "message",
        "type"
      ],
      "title": "ErrorMessage",
      "type": "object"
    },
    "EventFire": {
      "properties": {
        "duration_ms": {
          "title": "Duration Ms",
          "type": "integer"
        },
        "hotkey_id": {
          "title": "Hotkey Id",
          "type": "string"
        },
        "kind": {
          "const": "event",
          "default": "event",
          "title": "Kind",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "duration_ms",
        "hotkey_id",
        "kind",
        "name"
      ],
      "title": "EventFire",
      "type": "object"
    },
    "ForceNewMessageMessage": {
      "description": "OLVT conversation_utils.py:181 -- turn seal (D-04).",
