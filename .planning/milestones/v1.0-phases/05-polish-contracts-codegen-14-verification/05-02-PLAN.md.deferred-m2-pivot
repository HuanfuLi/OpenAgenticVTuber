    Step 6 — Create `scripts/verify/port_collision_test.py`. Spawns the sidecar twice on `port:0`, asserts both bind cleanly on different ephemeral ports. The sidecar's `[READY] ws://127.0.0.1:<port>/ws` stdout line is the signal (per Phase 1 PLUMB-03 BYO-socket pattern locked in STATE.md).

    ```python
    """Phase 5 SC-01 / D-09 test 4: port-collision smoke.

    Spawns the sidecar twice on port:0 (ephemeral). Asserts:
      1. Both processes bind successfully (different ephemeral ports).
      2. Both print [READY] ws://127.0.0.1:<port>/ws within timeout.
      3. Cleaning up does not orphan either process.

    Confirms the BYO-socket port:0 pattern (locked Phase 1) is robust under
    repeated launches. This corresponds to PITFALLS.md Pitfall 11 (orphan
    Python process holds port).
    """
    from __future__ import annotations
    import os
    import re
    import signal
    import subprocess
    import sys
    import time
    from pathlib import Path

    REPO_ROOT = Path(__file__).resolve().parents[2]
    SIDECAR_VENV_PY = REPO_ROOT / "sidecar/.venv/Scripts/python.exe"
    if not SIDECAR_VENV_PY.exists():
        SIDECAR_VENV_PY = REPO_ROOT / "sidecar/.venv/bin/python"

    SIDECAR_MODULE = "sidecar.server"  # confirm at execute-time — match Phase 1 entry point
    READY_RE = re.compile(r"\[READY\]\s+ws://127\.0\.0\.1:(\d+)/ws")
    TIMEOUT_S = 30


    def spawn_one() -> tuple[subprocess.Popen, int]:
        """Spawn one sidecar; return (proc, ephemeral_port). Caller must terminate."""
        env = os.environ.copy()
        # Disable LLM precondition for port-collision smoke — we only care about WS bind.
        env["AGENTICLLMVTUBER_SKIP_LLM_PRECHECK"] = "1"
        proc = subprocess.Popen(
            [str(SIDECAR_VENV_PY), "-m", SIDECAR_MODULE],
            cwd=str(REPO_ROOT),
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            env=env,
            bufsize=1,
        )
        deadline = time.time() + TIMEOUT_S
        port: int | None = None
        while time.time() < deadline:
            line = proc.stdout.readline()
            if not line:
                if proc.poll() is not None:
                    raise RuntimeError(f"Sidecar exited before [READY] (rc={proc.returncode})")
                continue
            print(f"  [sidecar] {line.rstrip()}")
            m = READY_RE.search(line)
            if m:
                port = int(m.group(1))
                break
        if port is None:
            proc.terminate()
            raise TimeoutError(f"No [READY] line in {TIMEOUT_S}s")
        return proc, port


    def main() -> int:
        if not SIDECAR_VENV_PY.exists():
            print(f"FAIL: sidecar venv missing at {SIDECAR_VENV_PY}", file=sys.stderr)
            return 2

        procs: list[tuple[subprocess.Popen, int]] = []
        try:
            print("Spawning sidecar #1...")
            procs.append(spawn_one())
            print(f"  port #1 = {procs[0][1]}")

            print("Spawning sidecar #2 (concurrent)...")
            procs.append(spawn_one())
            print(f"  port #2 = {procs[1][1]}")

            if procs[0][1] == procs[1][1]:
                print("FAIL: both sidecars bound the same port (impossible if port:0 is used)")
                return 1
            print(f"PASS: ports differ ({procs[0][1]} vs {procs[1][1]}); BYO-socket port:0 pattern works.")
            return 0
        finally:
            for proc, _ in procs:
                if proc.poll() is None:
                    proc.terminate()
                    try:
                        proc.wait(timeout=5)
                    except subprocess.TimeoutExpired:
                        proc.kill()
                        proc.wait(timeout=2)


    if __name__ == "__main__":
        sys.exit(main())
    ```

