    Step 5 — Create `scripts/verify/olvt_protocol_diff.py`. AST-parses OLVT's websocket_handler.py to extract `_init_message_handlers` dict keys; introspects our `WSMessage` discriminator mapping; compares against the allowlist. Exits 0 if every divergence is in the allowlist, non-zero (with a clear error message) if any divergence is undocumented.

    ```python
    """Phase 5 SC-01 / D-09 test 5: OLVT protocol-shape parity diff.

    Compares the walking-skeleton WSMessage discriminator-union variants against
    OLVT's _init_message_handlers dict at the AGREED reference path:
        C:/Users/16079/Code/OpenLLM_Vtuber/src/open_llm_vtuber/websocket_handler.py
    (NO /server/ segment — this path correction is documented in 05-RESEARCH.md.)

    Strategy: AST-parse OLVT's file (no import — avoids OLVT's heavy dep chain).
    Expected divergences allowlisted in scripts/verify/olvt-protocol-divergences.json.

    Exit:
      0 — every divergence is documented; OLVT-shape parity intact.
      1 — at least one undocumented divergence detected; print details.
      2 — OLVT source not found at the expected path (env precondition fail).
    """
    from __future__ import annotations
    import ast
    import json
    import sys
    from pathlib import Path

    REPO_ROOT = Path(__file__).resolve().parents[2]
    sys.path.insert(0, str(REPO_ROOT / "packages/contracts/py"))

    from contracts import WSMessage  # noqa: E402

    # OLVT reference path (CORRECT — no /server/ segment).
    OLVT_HANDLER = Path(
        "C:/Users/16079/Code/OpenLLM_Vtuber/src/open_llm_vtuber/websocket_handler.py"
    )
    ALLOWLIST = Path(__file__).parent / "olvt-protocol-divergences.json"


    def extract_olvt_keys(source_file: Path) -> set[str]:
        """AST-parse the OLVT websocket_handler.py to find _init_message_handlers
        and extract the dict's keys."""
        tree = ast.parse(source_file.read_text(encoding="utf-8"))
        for node in ast.walk(tree):
            if isinstance(node, ast.FunctionDef) and node.name == "_init_message_handlers":
                # Find the return statement.
                for stmt in ast.walk(node):
                    if isinstance(stmt, ast.Return) and isinstance(stmt.value, ast.Dict):
                        keys: set[str] = set()
                        for k in stmt.value.keys:
                            if isinstance(k, ast.Constant) and isinstance(k.value, str):
                                keys.add(k.value)
                        return keys
        return set()


    def extract_our_keys() -> set[str]:
        """Read WSMessage discriminator mapping from Pydantic metadata."""
        from typing import get_args
        # WSMessage = Annotated[Union[...], Field(discriminator='type')]
        # __metadata__[0] is the Field instance with discriminator='type'.
        # The Pydantic-v2 way: build a TypeAdapter and read its discriminator.
        from pydantic import TypeAdapter
        ta = TypeAdapter(WSMessage)
        schema = ta.json_schema()
        mapping = schema.get("discriminator", {}).get("mapping", {})
        return set(mapping.keys())


    def main() -> int:
        if not OLVT_HANDLER.exists():
            print(f"FAIL: OLVT source not found at {OLVT_HANDLER}", file=sys.stderr)
            print("       Clone Open-LLM-VTuber to that path or update OLVT_HANDLER.", file=sys.stderr)
            return 2

